<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="defaultPattern" value="%d{HH:mm:ss.SSS} [%thread] %-5level%logger{36} - %msg%n" />
    <appender name="root-appender" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!--            <fileNamePattern>${CATALINA_HOME}/logs/paw2025a-11.warnings.%d{yyyy-MM-dd}.log</fileNamePattern>-->
            <fileNamePattern>logs/paw2025a-11.warnings.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>5</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${defaultPattern:-}</pattern>
        </encoder>
    </appender>

    <appender name="paw-appender" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!--            <fileNamePattern>${CATALINA_HOME}/logs/paw2025a-11.paw.%d{yyyy-MM-dd}.log</fileNamePattern>-->
            <fileNamePattern>logs/paw2025a-11.paw.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>5</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${defaultPattern:-}</pattern>
        </encoder>
    </appender>


    <root level="WARN">
        <appender-ref ref="root-appender" />
    </root>
    <logger name="ar.edu.itba.paw" level="INFO" additivity="false">
        <appender-ref ref="paw-appender" />
    </logger>
</configuration>

