
.form-group {
    position: relative;
    margin-bottom: 1.5rem;
}

.neighborhood-search-wrapper {
    position: relative;
}

.search-results-container {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: white;
    border: 1px solid #ddd;
    border-top: none;
    border-radius: 0 0 4px 4px;
    max-height: 200px;
    overflow-y: auto;
    z-index: 1000;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    display: none;
}

.search-result-item {
    padding: 8px 12px;
    cursor: pointer;
    border-bottom: 1px solid #f0f0f0;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: background-color 0.2s ease;
}

.search-result-item:hover {
    background-color: #f8f9fa;
}

.search-result-item:last-child {
    border-bottom: none;
}

.office-entry {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 20px;
    background: #fafafa;
    transition: opacity 0.3s ease, transform 0.3s ease;
}

.office-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: 15px;
}

.btn-remove {
    background: #dc3545;
    color: white;
    border: none;
    border-radius: 50%;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 14px;
    transition: background-color 0.2s ease;
}

.btn-remove:hover {
    background: #c82333;
}

.btn-remove:focus {
    outline: none;
    box-shadow: 0 0 0 2px rgba(220, 53, 69, 0.25);
}

/* Custom checkbox styles */
.custom-checkbox {
    display: flex;
    align-items: center;
    padding: 8px 12px;
    cursor: pointer;
    border-bottom: 1px solid #f0f0f0;
    transition: background-color 0.2s ease;
    position: relative;
}

.custom-checkbox:hover {
    background-color: #f8f9fa;
}

.custom-checkbox:last-child {
    border-bottom: none;
}

.custom-checkbox input[type="checkbox"] {
    position: absolute;
    opacity: 0;
    cursor: pointer;
}

.custom-checkbox .checkmark {
    width: 18px;
    height: 18px;
    border: 2px solid #ddd;
    border-radius: 3px;
    margin-right: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    flex-shrink: 0;
}

.custom-checkbox input[type="checkbox"]:checked + .checkmark {
    background-color: #007bff;
    border-color: #007bff;
}

.custom-checkbox input[type="checkbox"]:checked + .checkmark::after {
    content: "✓";
    color: white;
    font-size: 12px;
    font-weight: bold;
}

.custom-checkbox .checkbox-label {
    flex: 1;
    font-size: 14px;
}

.custom-multi-select {
    border: 1px solid #ddd;
    border-radius: 4px;
    max-height: 200px;
    overflow-y: auto;
    background: white;
}

.selected-options {
    margin-top: 10px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    min-height: 20px;
}

.specialty-tag {
    background-color: #007bff;
    color: white;
    padding: 4px 8px;
    border-radius: 12px;
    font-size: 12px;
    display: inline-block;
}

/* Form validation styles */
.input-wrapper {
    position: relative;
}

.validation-icon {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    opacity: 0;
    transition: opacity 0.2s ease;
}

.validation-icon.valid {
    color: #28a745;
}

.validation-icon.error {
    color: #dc3545;
}

.form-control.valid + .validation-icon.valid {
    opacity: 1;
}

.form-control.error + .validation-icon.error {
    opacity: 1;
}

.error-message {
    color: #dc3545;
    font-size: 0.875rem;
    margin-top: 0.25rem;
    opacity: 0;
    transition: opacity 0.2s ease;
}

.error-message.visible {
    opacity: 1;
}

/* Responsive design */
@media (max-width: 768px) {
    .office-entry {
        padding: 15px;
    }

    .form-row {
        flex-direction: column;
    }

    .search-results-container {
        max-height: 150px;
    }
}
