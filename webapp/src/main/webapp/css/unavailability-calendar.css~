/* Unavailability Calendar Styles */

.unavailability-calendar{
    display: flex;
    flex-direction: column;
    align-content: center;
    justify-content: center;
    gap: 1rem;
}
.unavailability-calendar-container {
    background-color: var(--white);
    border-radius: var(--border-radius-lg);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid #e2e8f0;
    width: 40rem;
}

/* Calendar Header */
.calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: linear-gradient(135deg, var(--primary-light) 0%, rgba(147, 197, 253, 0.3) 100%);
    border-radius: var(--border-radius);
}

.calendar-month-year {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-color);
    text-align: center;
    flex: 1;
}

.calendar-nav-btn {
    background: var(--white);
    border: 1px solid var(--primary-light);
    border-radius: 50%;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition);
    color: var(--primary-color);
}

.calendar-nav-btn:hover:not(:disabled) {
    background-color: var(--primary-color);
    color: var(--white);
    transform: scale(1.05);
}

.calendar-nav-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
}

/* Calendar Grid */
.calendar-grid {
    margin-bottom: 1.5rem;
}

.calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 1px;
    margin-bottom: 0.5rem;
    background-color: var(--background-light);
    border-radius: var(--border-radius);
    padding: 0.5rem;
}

.calendar-weekday {
    text-align: center;
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-light);
    padding: 0.5rem;
}

.calendar-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
    background-color: #f1f5f9;
    padding: 2px;
    border-radius: var(--border-radius);
}

.calendar-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--white);
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: var(--transition);
    position: relative;
    min-height: 2.5rem;
}

.calendar-day.empty {
    background-color: transparent;
    cursor: default;
}

.calendar-day.disabled {
    background-color: #f8fafc;
    color: #cbd5e1;
    cursor: not-allowed;
}

.calendar-day.available:hover {
    background-color: var(--primary-light);
    color: var(--primary-dark);
    transform: scale(1.05);
}

/* Unavailability States */
.calendar-day.unavailable {
    background-color: #ef4444;
    color: var(--white);
    font-weight: 600;
}

.calendar-day.range-start {
    background-color: #ef4444;
    color: var(--white);
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
    font-weight: 600;
}

.calendar-day.range-end {
    background-color: #ef4444;
    color: var(--white);
    border-top-left-radius: 0;
    border-bottom-left-radius: 0;
    font-weight: 600;
}

.calendar-day.in-range {
    background-color: rgba(239, 68, 68, 0.7);
    color: var(--white);
    border-radius: 0;
}

/* Temporary Selection States */
.calendar-day.temp-start {
    background-color: var(--success-color);
    color: var(--white);
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
    font-weight: 600;
}

.calendar-day.temp-end {
    background-color: var(--success-color);
    color: var(--white);
    border-top-left-radius: 0;
    border-bottom-left-radius: 0;
    font-weight: 600;
}

.calendar-day.temp-range {
    background-color: rgba(16, 185, 129, 0.7);
    color: var(--white);
    border-radius: 0;
}

.calendar-day.temp-single {
    background-color: var(--success-color);
    color: var(--white);
    font-weight: 600;
}

/* Hover effects for unavailable dates */
.calendar-day.unavailable:hover,
.calendar-day.range-start:hover,
.calendar-day.range-end:hover,
.calendar-day.in-range:hover {
    opacity: 0.8;
    cursor: context-menu;
}

/* Calendar Legend */
.calendar-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding: 1rem;
    background-color: var(--background-light);
    border-radius: var(--border-radius);
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-color);
}

.legend-color {
    width: 1rem;
    height: 1rem;
    border-radius: 3px;
    flex-shrink: 0;
}

.legend-color.unavailable {
    background-color: #ef4444;
}

.legend-color.range-start {
    background-color: #ef4444;
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
}

.legend-color.range-end {
    background-color: #ef4444;
    border-top-left-radius: 0;
    border-bottom-left-radius: 0;
}

.legend-color.in-range {
    background-color: rgba(239, 68, 68, 0.7);
    border-radius: 0;
}

/* Selection Info */
.selection-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(16, 185, 129, 0.05) 100%);
    border: 1px solid rgba(16, 185, 129, 0.3);
    border-radius: var(--border-radius);
    margin-bottom: 1rem;
}

.selection-text {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    color: var(--text-color);
}

.selection-text i {
    color: var(--success-color);
}

.selection-actions {
    display: flex;
    gap: 0.5rem;
}

/* Loading Indicator */
.calendar-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 2rem;
    color: var(--text-light);
    font-size: 0.9rem;
}

.calendar-loading i {
    color: var(--primary-color);
}

/* Responsive Design */
@media (max-width: 768px) {
    .unavailability-calendar-container {
        padding: 1rem;
    }

    .calendar-header {
        padding: 0.75rem;
    }

    .calendar-month-year {
        font-size: 1.1rem;
    }

    .calendar-nav-btn {
        width: 2rem;
        height: 2rem;
    }

    .calendar-day {
        min-height: 2rem;
        font-size: 0.8rem;
    }

    .calendar-legend {
        flex-direction: column;
        gap: 0.75rem;
    }

    .selection-info {
        flex-direction: column;
        gap: 1rem;
        align-items: stretch;
    }

    .selection-actions {
        justify-content: center;
    }
}

@media (max-width: 576px) {
    .calendar-weekdays {
        padding: 0.25rem;
    }

    .calendar-weekday {
        font-size: 0.75rem;
        padding: 0.25rem;
    }

    .calendar-day {
        min-height: 1.75rem;
        font-size: 0.75rem;
    }

    .selection-actions {
        flex-direction: column;
    }

    .selection-actions .btn {
        width: 100%;
    }
}

/* Animation for calendar transitions */
@keyframes fadeInCalendar {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.calendar-days {
    animation: fadeInCalendar 0.3s ease;
}

/* Tooltip styles for context menu hint */
.calendar-day[title] {
    position: relative;
}

.calendar-day[title]:hover::after {
    content: attr(title);
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    background-color: rgba(0, 0, 0, 0.8);
    color: white;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    white-space: nowrap;
    z-index: 1000;
    margin-bottom: 0.25rem;
}

/* Enhanced button styles */
.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: var(--border-radius);
    font-weight: 500;
    font-size: 0.85rem;
    transition: var(--transition);
    cursor: pointer;
    border: none;
    text-decoration: none;
    font-family: "Poppins", sans-serif;
}

.btn-primary {
    background-color: var(--primary-color);
    color: var(--white);
}

.btn-primary:hover {
    background-color: var(--primary-dark);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

.btn-secondary {
    background-color: var(--background-light);
    color: var(--text-color);
    border: 1px solid #e2e8f0;
}

.btn-secondary:hover {
    background-color: #e2e8f0;
    transform: translateY(-2px);
}

/* Error message styling */
#unavailability-error {
    background-color: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-left: 4px solid #ef4444;
    color: #dc2626;
    padding: 0.75rem 1rem;
    border-radius: var(--border-radius);
    margin-top: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

#unavailability-error::before {
    content: "\f071";
    font-family: "Font Awesome 6 Free", serif;
    font-weight: 900;
    color: #ef4444;
}
