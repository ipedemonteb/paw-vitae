/* Multiple Date Picker Styles */
.date-picker-container {
    position: relative;
    margin-bottom: 1rem;
}

.date-picker-input {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.375rem;
    font-size: 1rem;
    background-color: white;
    cursor: pointer;
    transition: border-color 0.2s ease;
}

.date-picker-input:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.1);
}

.date-picker-input:hover {
    border-color: #3b82f6;
}

/* Calendar Styles */
.date-picker-calendar {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 1000;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    overflow: hidden;
    margin-top: 0.25rem;
}

.date-picker-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    background-color: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
}

.date-picker-month-year {
    font-weight: 600;
    text-align: center;
    flex-grow: 1;
    font-size: 1rem;
    color: #1e293b;
}

.date-picker-nav {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.25rem;
    padding: 0.5rem;
    color: #3b82f6;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    width: 2rem;
    height: 2rem;
}

.date-picker-nav:hover {
    background-color: rgba(59, 130, 246, 0.1);
}

.date-picker-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    padding: 0.5rem 0;
    background-color: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
    font-weight: 500;
    font-size: 0.875rem;
    color: #64748b;
}

.date-picker-weekday {
    padding: 0.25rem;
}

.date-picker-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    padding: 0.5rem;
    gap: 2px;
}

.date-picker-day {
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    transition: all 0.2s ease;
    color: #1e293b;
}

.date-picker-day:hover:not(.disabled):not(.empty) {
    background-color: #f1f5f9;
}

.date-picker-day.selected {
    background-color: #3b82f6;
    color: white;
    font-weight: 600;
}

.date-picker-day.disabled {
    color: #cbd5e1;
    cursor: default;
    pointer-events: none;
}

.date-picker-day.empty {
    cursor: default;
}

.date-picker-day.available {
    cursor: pointer;
}

.date-picker-day.available:hover {
    background-color: #e0f2fe;
    color: #0369a1;
}

/* Form integration */
.form-group .date-picker-container {
    margin-bottom: 0;
}

/* Responsive design */
@media (max-width: 768px) {
    .date-picker-calendar {
        left: -1rem;
        right: -1rem;
    }

    .date-picker-day {
        height: 2rem;
        font-size: 0.75rem;
    }

    .date-picker-header {
        padding: 0.75rem;
    }
}

/* Error states */
.date-picker-input.error {
    border-color: #ef4444;
}

.date-picker-input.error:focus {
    border-color: #ef4444;
    box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.1);
}
